{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/assets/**",
          "!**/.*"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-open-meteo",
      "urls": [
        "https://api.open-meteo.com/**",
        "https://geocoding-api.open-meteo.com/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "30m",
        "timeout": "10s"
      }
    },
    {
      "name": "api-geocoding",
      "urls": [
        "https://nominatim.openstreetmap.org/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "24h",
        "timeout": "15s"
      }
    }
  ],
  "navigateFallback": "/index.html",
  "navigationUrls": [
    "/**",
    "!/**/*.js",
    "!/**/*.css",
    "!/**/*.json",
    "!/**/*.txt"
  ]
}